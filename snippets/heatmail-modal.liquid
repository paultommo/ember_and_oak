<div class="heatmail-overlay" id="heatmail-overlay" aria-hidden="true">
  <div class="heatmail-modal" role="dialog" aria-modal="true" aria-labelledby="heatmail-title">
    <button class="heatmail-close" id="heatmail-close" aria-label="Close">&times;</button>
    <div class="heatmail-body">
      <div class="heatmail-eyebrow">
        {%- if settings.logo != blank -%}
          {{ settings.logo | image_url: width: 160 | image_tag: class: 'heatmail-logo', alt: shop.name }}
        {%- else -%}
          <span class="heatmail-logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </div>
      <h2 class="heatmail-title" id="heatmail-title">The heat is on</h2>
      <p class="heatmail-copy">Get 10% off when you sign up to Heatmail</p>
      {%- form 'customer', id: 'heatmail-form', class: 'heatmail-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,heatmail">
        <div class="heatmail-field">
          <input
            type="email"
            name="contact[email]"
            id="heatmail-email"
            placeholder="Your email address"
            required
            autocomplete="email"
            class="heatmail-input"
          >
          <button type="submit" class="heatmail-submit">Sign Me Up</button>
        </div>
        {%- if form.errors -%}
          <p class="heatmail-error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <p class="heatmail-success">You're in. Check your inbox for your 10% off code.</p>
        {%- endif -%}
      {%- endform -%}
      <button class="heatmail-skip" id="heatmail-skip">No thanks, I like full price</button>
    </div>
  </div>
</div>

<style>
  .heatmail-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .heatmail-overlay.is-visible {
    opacity: 1;
    pointer-events: all;
  }

  .heatmail-modal {
    background: #FE4B20;
    max-width: 520px;
    width: 90%;
    padding: 5.6rem 4.8rem 4rem;
    position: relative;
    text-align: center;
  }

  .heatmail-close {
    position: absolute;
    top: 1.6rem;
    right: 2rem;
    background: none;
    border: none;
    font-size: 3rem;
    font-weight: 700;
    color: #000;
    cursor: pointer;
    line-height: 1;
    padding: 0;
  }

  .heatmail-eyebrow {
    font-size: 4rem;
    margin: 0 0 1.2rem;
  }

  .heatmail-title {
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 4.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 1.2rem;
    line-height: 1.05;
  }

  .heatmail-copy {
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 1.8rem;
    font-weight: 700;
    color: #000;
    margin: 0 0 3.2rem;
  }

  .heatmail-field {
    display: flex;
    gap: 0;
  }

  .heatmail-input {
    flex: 1;
    padding: 1.2rem 1.6rem;
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 1.5rem;
    border: none;
    background: #fff;
    color: #000;
    outline: none;
  }

  .heatmail-input::placeholder {
    color: #888;
  }

  .heatmail-submit {
    background: #000;
    color: #fff;
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 1.4rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: none;
    padding: 1.2rem 2.4rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .heatmail-submit:hover {
    background: #EBDA2F;
    color: #000;
  }

  .heatmail-skip {
    display: block;
    margin: 2rem auto 0;
    background: none;
    border: none;
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 1.2rem;
    color: #000;
    text-decoration: underline;
    cursor: pointer;
    padding: 0;
  }

  .heatmail-error {
    color: #000;
    font-size: 1.3rem;
    margin-top: 1rem;
  }

  .heatmail-success {
    color: #000;
    font-size: 1.6rem;
    font-weight: 700;
    margin-top: 1.6rem;
  }
</style>

<script>
  (function () {
    const STORAGE_KEY = 'eo_heatmail_shown';

    function closeModal() {
      const overlay = document.getElementById('heatmail-overlay');
      overlay.classList.remove('is-visible');
      overlay.setAttribute('aria-hidden', 'true');
      localStorage.setItem(STORAGE_KEY, '1');
    }

    function initModal() {
      if (localStorage.getItem(STORAGE_KEY)) return;

      const overlay = document.getElementById('heatmail-overlay');
      const closeBtn = document.getElementById('heatmail-close');
      const skipBtn = document.getElementById('heatmail-skip');

      setTimeout(() => {
        overlay.classList.add('is-visible');
        overlay.setAttribute('aria-hidden', 'false');
      }, 1500);

      closeBtn.addEventListener('click', closeModal);
      skipBtn.addEventListener('click', closeModal);
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) closeModal();
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initModal);
    } else {
      initModal();
    }
  })();
</script>
