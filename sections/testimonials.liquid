<div class="testimonials">
  <div class="testimonials__scroller page-width">

    <button class="testimonials__nav testimonials__nav--prev" aria-label="Previous">&#8592;</button>

    <div class="testimonials__track">

      <div class="testimonial is-active">
        <div class="testimonial__stars">★★★★★</div>
        <blockquote class="testimonial__quote">
          "Slow Burn has permanently replaced every other hot sauce in my kitchen. The smokiness is unlike anything I've tried — heat that actually builds instead of just burning."
        </blockquote>
        <p class="testimonial__author">— Jamie R., Manchester</p>
      </div>

      <div class="testimonial">
        <div class="testimonial__stars">★★★★★</div>
        <blockquote class="testimonial__quote">
          "Ordered the Starter Kit as a gift and ended up keeping it. Oak & Ember Original is my desert island sauce. Balanced, complex, and dangerously addictive."
        </blockquote>
        <p class="testimonial__author">— Priya M., London</p>
      </div>

      <div class="testimonial">
        <div class="testimonial__stars">★★★★★</div>
        <blockquote class="testimonial__quote">
          "I thought I could handle The Inferno. I was wrong. But I went back for more the next day. That's how good it is. Ember & Oak have ruined supermarket hot sauce for me forever."
        </blockquote>
        <p class="testimonial__author">— Dan T., Glasgow</p>
      </div>

    </div>

    <button class="testimonials__nav testimonials__nav--next" aria-label="Next">&#8594;</button>

  </div>

  <div class="testimonials__dots page-width">
    <button class="testimonials__dot is-active" data-index="0" aria-label="Testimonial 1"></button>
    <button class="testimonials__dot" data-index="1" aria-label="Testimonial 2"></button>
    <button class="testimonials__dot" data-index="2" aria-label="Testimonial 3"></button>
  </div>
</div>

<style>
  .testimonials {
    background: #EBDA2F;
    padding: 60px 0;
  }

  .testimonials__scroller {
    display: flex;
    align-items: center;
    gap: 2.4rem;
  }

  .testimonials__track {
    flex: 1;
    position: relative;
    min-height: 18rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .testimonial {
    display: none;
    flex-direction: column;
    gap: 1.6rem;
    text-align: center;
    max-width: 700px;
    width: 100%;
  }

  .testimonial.is-active {
    display: flex;
  }

  .testimonial__stars {
    font-size: 2.4rem;
    color: #000;
    letter-spacing: 0.1em;
  }

  .testimonial__quote {
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 2rem;
    font-weight: 700;
    color: #000;
    line-height: 1.5;
    margin: 0;
    font-style: normal;
  }

  .testimonial__author {
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 1.3rem;
    color: #000;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .testimonials__nav {
    background: #000;
    color: #fff;
    border: none;
    font-size: 2.4rem;
    font-weight: 700;
    width: 5rem;
    height: 5rem;
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .testimonials__nav:hover {
    background: #FE4B20;
  }

  .testimonials__dots {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.4rem;
  }

  .testimonials__dot {
    width: 1.2rem;
    height: 1.2rem;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.3);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease;
  }

  .testimonials__dot.is-active {
    background: #000;
  }

  @media screen and (max-width: 749px) {
    .testimonials__nav {
      width: 4rem;
      height: 4rem;
      font-size: 1.8rem;
    }

    .testimonial__quote {
      font-size: 1.6rem;
    }
  }
</style>

<script>
  (function () {
    const items = document.querySelectorAll('.testimonials .testimonial');
    const dots = document.querySelectorAll('.testimonials .testimonials__dot');
    let current = 0;

    function show(index) {
      items[current].classList.remove('is-active');
      dots[current].classList.remove('is-active');
      current = (index + items.length) % items.length;
      items[current].classList.add('is-active');
      dots[current].classList.add('is-active');
    }

    document.querySelector('.testimonials__nav--prev').addEventListener('click', () => show(current - 1));
    document.querySelector('.testimonials__nav--next').addEventListener('click', () => show(current + 1));
    dots.forEach((dot) => dot.addEventListener('click', () => show(parseInt(dot.dataset.index))));
  })();
</script>

{% schema %}
{
  "name": "Testimonials",
  "settings": [],
  "presets": [
    {
      "name": "Testimonials"
    }
  ]
}
{% endschema %}
