<div class="hero-custom">
  <div class="hero-custom__inner page-width">
    <div class="hero-custom__col hero-custom__col--text">
      <h1 class="hero-custom__headline">It doesn't get hotter than this</h1>
      <a href="{{ routes.all_products_collection_url }}" class="hero-custom__cta">Shop Now</a>
      <div class="hero-custom__reviews">
        <span class="hero-custom__stars">★★★★★</span>
        <span class="hero-custom__review-count">5872 reviews</span>
      </div>
      <div class="hero-custom__highlights">
        <div class="hero-custom__highlight">
          <strong>Small Batch</strong>
          <p>Every sauce is made in small runs to ensure quality and consistency in every bottle.</p>
        </div>
        <div class="hero-custom__highlight">
          <strong>Real Ingredients</strong>
          <p>No fillers, no artificial flavours. Just peppers, vinegar, spices, and fire.</p>
        </div>
        <div class="hero-custom__highlight">
          <strong>Oak-Smoked</strong>
          <p>Our peppers are slow-roasted over oak wood to build flavour before the heat kicks in.</p>
        </div>
      </div>
    </div>
    <div class="hero-custom__col hero-custom__col--image">
      <img
        src="{{ 'jar.png' | asset_url }}"
        alt="Ember & Oak hot sauce jar"
        class="hero-custom__image"
        loading="eager"
      >
    </div>
  </div>
</div>

<style>
  .hero-custom {
    background-color: #FE4B20;
    padding: 80px 0;
  }

  .hero-custom__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: start;
    gap: 60px;
  }

  .hero-custom__headline {
    font-size: 6rem;
    font-weight: 700;
    color: #000;
    text-transform: uppercase;
    line-height: 1.05;
    margin: 0 0 3.2rem;
    font-family: Arial, Helvetica, sans-serif;
  }

  .hero-custom__reviews {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .hero-custom__stars {
    font-size: 3rem;
    color: #000;
    line-height: 1;
  }

  .hero-custom__review-count {
    font-size: 2rem;
    font-weight: 700;
    color: #000;
    font-family: Arial, Helvetica, sans-serif;
  }

  .hero-custom__image {
    width: 100%;
    max-width: 560px;
    display: block;
    margin: 0 auto;
  }

  .hero-custom__cta {
    display: inline-block;
    background-color: #000;
    color: #fff !important;
    font-family: Arial, Helvetica, sans-serif;
    font-size: 1.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 1.4rem 3.6rem;
    margin-bottom: 3.2rem;
    text-decoration: none !important;
  }

  .hero-custom__cta:hover {
    background-color: #EBDA2F;
    color: #000 !important;
  }

  .hero-custom__highlights {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-custom__highlight strong {
    display: block;
    font-size: 1.8rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    font-family: Arial, Helvetica, sans-serif;
    margin-bottom: 0.4rem;
  }

  .hero-custom__highlight p {
    font-size: 1.4rem;
    color: #000;
    margin: 0;
    font-family: Arial, Helvetica, sans-serif;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .hero-custom__inner {
      grid-template-columns: 1fr;
    }

    .hero-custom__headline {
      font-size: 4rem;
    }

    .hero-custom__col--image {
      order: -1;
    }
  }
</style>

{% schema %}
{
  "name": "Custom Hero",
  "settings": [],
  "presets": [
    {
      "name": "Custom Hero"
    }
  ]
}
{% endschema %}
