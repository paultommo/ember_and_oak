<div class="recipe-section">
  <div class="recipe-section__header page-width">
    <h2 class="recipe-section__title">Fire Up the Kitchen</h2>
  </div>

  <div class="recipe-section__grid page-width">

    <a href="/blogs/recipes/smoked-wings" class="recipe-card">
      <div class="recipe-card__image" style="background: #1C1C1C;">
        <img src="{{ 'hot-sauce.png' | asset_url }}" alt="Smoked Wings" class="recipe-card__img">
      </div>
      <p class="recipe-card__title">Ember & Oak Smoked Wings</p>
    </a>

    <a href="/blogs/recipes/pitmaster-ribs" class="recipe-card">
      <div class="recipe-card__image" style="background: #5C6B3A;">
        <img src="{{ 'bbq-sauce.png' | asset_url }}" alt="BBQ Ribs" class="recipe-card__img">
      </div>
      <p class="recipe-card__title">Pitmaster Sticky Ribs</p>
    </a>

    <a href="/blogs/recipes/hellfire-burger" class="recipe-card">
      <div class="recipe-card__image" style="background: #D4521A;">
        <img src="{{ 'jar.png' | asset_url }}" alt="Hellfire Burger" class="recipe-card__img">
      </div>
      <p class="recipe-card__title">Hellfire Smash Burger</p>
    </a>

    <a href="/blogs/recipes/signature-brisket" class="recipe-card">
      <div class="recipe-card__image" style="background: #3A2A1A;">
        <img src="{{ 'dry-rub.png' | asset_url }}" alt="Brisket" class="recipe-card__img">
      </div>
      <p class="recipe-card__title">Signature Rub Brisket</p>
    </a>

  </div>
</div>

<style>
  .recipe-section {
    background: #EBDA2F;
    padding: 60px 0;
  }

  .recipe-section__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .recipe-section__title {
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 3.6rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    margin: 0;
  }

  .recipe-section__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2.4rem;
  }

  .recipe-card {
    display: flex;
    flex-direction: column;
    text-decoration: none !important;
  }

  .recipe-card__image {
    aspect-ratio: 1;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .recipe-card:hover .recipe-card__image {
    opacity: 0.85;
  }

  .recipe-card__img {
    width: 80%;
    height: 80%;
    object-fit: contain;
    display: block;
  }

  .recipe-card__title {
    font-family: Arial, Helvetica, sans-serif !important;
    font-size: 1.6rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    margin: 1.2rem 0 0;
    line-height: 1.2;
  }

  @media screen and (max-width: 989px) {
    .recipe-section__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .recipe-section__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .recipe-section__title {
      font-size: 2.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Recipe Section",
  "settings": [],
  "presets": [
    {
      "name": "Recipe Section"
    }
  ]
}
{% endschema %}
